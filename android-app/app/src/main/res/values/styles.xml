<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Euno Theme -->
    <style name="Theme.Euno" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_hover</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_dark</item>
        <item name="colorSecondaryVariant">@color/accent_dark_hover</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_app</item>
        <item name="colorSurface">@color/bg_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Setup/Settings Theme (dark background) -->
    <style name="Theme.Euno.Setup" parent="Theme.Euno">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <!-- Main Theme (WebView - light) -->
    <style name="Theme.Euno.Main" parent="Theme.Euno">
        <item name="android:windowBackground">@color/bg_app</item>
    </style>

    <!-- Input field style -->
    <style name="Euno.EditText" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_placeholder</item>
        <item name="android:background">@drawable/rounded_input</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Primary button style -->
    <style name="Euno.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/rounded_button</item>
    </style>

    <!-- Card style -->
    <style name="Euno.Card" parent="">
        <item name="android:background">@drawable/rounded_card</item>
        <item name="android:padding">32dp</item>
        <item name="android:elevation">8dp</item>
    </style>

</resources>
