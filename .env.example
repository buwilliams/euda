# LLM Provider API Keys
# Configure your preferred provider in data/system/config.json

# Anthropic API Key (for Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (for GPT models)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# xAI API Key (for Grok models)
# Get your key from: https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here

# Deployment Server (optional)
# Used by devops scripts: deploy-euno.sh, sync-data.sh, manage.sh
# Example: root@192.168.1.100 or user@example.com
EUNO_SERVER=
