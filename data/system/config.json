{
  "version": "3.0.0",
  "initialized": true,
  "metacognition": {
    "progress": {
      "max_tool_calls_per_iteration": 50,
      "max_repeated_tool_calls": 3,
      "max_no_progress_iterations": 5
    },
    "planning": {
      "enabled": true,
      "excluded_for": []
    },
    "efficiency": {
      "defer_consolidation_in_work_cycles": true
    },
    "consolidation": {
      "append_max_tokens": 500,
      "append_batch_max_tokens": 1000,
      "consolidate_max_tokens": 2000,
      "upload_analysis_max_tokens": 1000
    },
    "patterns": {
      "enabled": true,
      "discovery_passes": ["temporal", "correlation", "trajectory"],
      "min_evidence_for_pattern": 3,
      "hypothesis_expiry_days": 30,
      "confidence_decay_rate": 0.1,
      "confidence_boost_on_validation": 0.15
    }
  },
  "rlm": {
    "enabled": true,
    "max_iterations": 20,
    "max_recursion_depth": 1,
    "execution_timeout_seconds": 30,
    "output_truncation_chars": 10000
  },
  "logging": {
    "level": "info",
    "retention_days": 31
  },
  "agents": {
    "max_work_iterations": 20,
    "poll_interval": 0.1
  },
  "schedules": {
    "morning": "08:00",
    "evening": "18:00",
    "hourly": "every_hour",
    "hour_00": "00:00",
    "hour_04": "04:00",
    "hour_06": "06:00",
    "hour_12": "12:00",
    "hour_18": "18:00"
  },
  "nextcloud": {
    "instances": {
      "personal": {
        "display_name": "Personal Nextcloud instance",
        "url": "https://example.nextcloud.url",
        "username": ""
      }
    },
    "default_instance": "personal"
  }
}
