<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <!-- Centered content container -->
    <LinearLayout
        android:id="@+id/setupContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/rounded_card"
        android:padding="32dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="360dp">

        <!-- Logo/Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_subtitle"
            android:textSize="16sp"
            android:textColor="@color/text_light"
            android:layout_marginBottom="32dp" />

        <!-- Server IP Input -->
        <EditText
            android:id="@+id/serverIpInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/setup_ip_hint"
            android:inputType="text"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:background="@drawable/rounded_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp"
            android:importantForAutofill="no" />

        <!-- Port Input -->
        <EditText
            android:id="@+id/serverPortInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/setup_port_hint"
            android:inputType="number"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:background="@drawable/rounded_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp"
            android:importantForAutofill="no" />

        <!-- Connect Button -->
        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/setup_connect"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/loadingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="@color/accent" />

        <!-- Error message -->
        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp"
            android:textColor="@color/danger"
            android:textAlignment="center"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
