# Environment
.env

# ===================
# Data Directory Rules
# ===================

# Agent configs and personas ARE code (track them)
!data/agents/*/config.json
!data/agents/*/*.md

# Agent state is runtime data (ignore)
data/agents/*/state/

# Jobs are user data (ignore)
data/jobs/*.json

# Assets are user data (ignore)
data/assets/

# User data (ignore)
data/user/

# System config can be tracked, but may contain secrets
data/system/*.json

# Keep directory structure
!data/**/.gitkeep

# Backups
data_backup-*/

# ===================
# Old Architecture
# ===================
# Keep old-architecture tracked for reference
# But ignore its data directory (user data)
old-architecture/data/

# ===================
# Python
# ===================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

