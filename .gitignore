# Environment
.env

# User data - ignore personal data but keep structure and identity templates
# Ignore all files in data
data/**/*.json
data/**/*.md
data/**/*.txt
data/**/*.signal
# Inbox files (ingested content)
data/ingestion/inbox/**/*
# But keep .gitkeep files (for directory structure)
!data/**/.gitkeep
# And keep identity templates (not personal data)
!data/shared/identity/*.md
# And keep profile contract/policy (system config, not user data)
!data/shared/profile/profile.contract.md
!data/shared/profile/redaction.policy.md
# And keep prompts (code/configuration, not user data)
!data/*/prompts/*.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

