# Environment
.env

# ===================
# Data Directory Rules
# ===================

# ===================
# Base Agents (data/agents/)
# ===================
# Only user, chat, and worker are committed - other agents are user-created
# Track config.json and identity.template.md (templates)
# Actual identity.md files are user data and ignored
!data/agents/user/config.json
!data/agents/user/identity.template.md
data/agents/user/identity.md
!data/agents/chat/config.json
!data/agents/chat/identity.template.md
data/agents/chat/identity.md
!data/agents/chat/prompts/
!data/agents/worker/config.json
!data/agents/worker/identity.template.md
data/agents/worker/identity.md
!data/agents/worker/prompts/

# ===================
# Agent Library (agent-lib/)
# ===================
# Shareable agent templates - track config, identity, prompts only
!agent-lib/
!agent-lib/*/
!agent-lib/*/config.json
!agent-lib/*/identity.md
!agent-lib/*/prompts/

# Runtime data in agent-lib is ignored
agent-lib/*/memory/
agent-lib/*/state/
agent-lib/*/state.json
agent-lib/*/logs/

# Agent memory is runtime data (ignore entire directory)
data/agents/*/memory/

# Agent costs and uploads are runtime data (ignore)
data/agents/*/costs/
data/agents/*/uploads/

# Agent state is runtime data (ignore)
data/agents/*/state/
data/agents/*/state.json

# Agent logs are runtime data (ignore)
data/agents/*/logs/

# Topics database is user data (ignore)
data/topics/db.sqlite
data/topics/db.sqlite-journal
data/topics/db.sqlite-wal
data/topics/db.sqlite-shm

# Assets are user data (ignore)
data/topics/assets/

# System config is tracked (contains settings, not secrets)
!data/system/config.json
# But ignore other system files that may contain secrets or user state
data/system/state.json
data/system/auth.json
data/system/sessions.json
data/system/quotes.json
data/system/prompts.jsonl
data/system/prompts/*.jsonl
data/system/logs/
data/system/incidents/
data/system/api_calls.json
data/system/api_calls.jsonl
data/system/store/
data/system/token_usage/
data/system/sync/*
!data/system/sync/.gitkeep

# User data directory (personal data)
data/user/

# Plugin data (credentials, user config)
data/plugins/

# Keep directory structure
!data/**/.gitkeep

# Backups
data_backup-*/
data/topics_backup_*/

# ===================
# Old Architecture
# ===================
# Keep old-architecture tracked for reference
# But ignore its data directory (user data)
old-architecture/data/

# ===================
# Testing
# ===================
.coverage
htmlcov/
.pytest_cache/

# ===================
# Python
# ===================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# ===================
# IDE
# ===================
.idea/
.vscode/
*.swp
*.swo
*~

# ===================
# OS
# ===================
.DS_Store
Thumbs.db

# ===================
# DevOps / Diagnostics
# ===================
devops/DIAGNOSTICS-README.md
devops/collect-diagnostics.sh
devops/collect-user-diagnostics.sh
devops/get-diagnostics-from-server.ps1
devops/get-diagnostics-from-server.sh
euno-diagnostics-*.tar.gz

# ===================
# Personal Data
# ===================
lifelog/

