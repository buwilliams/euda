# Environment
.env

# User data - ignore personal data but keep structure and system config
# Ignore all files in data
data/**/*.json
data/**/*.md
data/**/*.txt
data/**/*.signal
data/**/*.hash
# Lifelog directories (personal data)
data/shared/state/lifelog/
# Inbox files (ingested content)
data/archivist/state/inbox/**/*
# But keep .gitkeep files (for directory structure)
!data/**/.gitkeep
# And keep profile contract/policy (system config, not user data)
# Note: Agent personas moved to src/agents/personas/ (tracked by git)
!data/shared/state/profile/profile.contract.md
!data/shared/state/profile/redaction.policy.md

# Fresh start backups (personal data)
data_backup-*/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
